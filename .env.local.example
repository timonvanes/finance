# Supabase (Settings -> API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# GoCardless Bank Account Data (bankaccountdata.gocardless.com -> User secrets)
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=

# Random secret used to encrypt bank tokens at rest (e.g. `openssl rand -hex 32`)
ENCRYPTION_KEY=

# Auto-set by Vercel Cron; only needed locally if you want to hit the cron route manually
CRON_SECRET=
