# Supabase (Settings -> API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Enable Banking (enablebanking.com/sign-in -> Control Panel -> Applications)
# ENABLE_BANKING_APPLICATION_ID is shown in the Control Panel.
# ENABLE_BANKING_PRIVATE_KEY is the full contents of the downloaded .pem file
# (paste with \n line breaks kept literal, or use a single-line escaped form).
ENABLE_BANKING_APPLICATION_ID=
ENABLE_BANKING_PRIVATE_KEY=

# Random secret used to encrypt bank tokens at rest (e.g. `openssl rand -hex 32`)
ENCRYPTION_KEY=

# Auto-set by Vercel Cron; only needed locally if you want to hit the cron route manually
CRON_SECRET=
